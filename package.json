{
  "name": "@tiny-owl-kit/observability",
  "version": "1.3.1",
  "description": "TinyOwl JavaScript SDK - Lightweight observability and logging with enterprise-grade security",
  "keywords": [
    "observability",
    "logging",
    "monitoring",
    "tinyowl",
    "security",
    "hmac",
    "analytics"
  ],
  "author": "TinyOwl - Vladimir Rancic <vladimir.rancic@np011.se>",
  "license": "MIT",
  "homepage": "https://tiny-owl-kit.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/net-partner-011-ab/tiny-owl-js",
    "directory": "tiny-owl-js"
  },
  "bugs": {
    "url": "https://github.com/net-partner-011-ab/tiny-owl-js/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --watch",
    "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:node": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest --testEnvironment=node",
    "test:browser": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest --testEnvironment=jsdom",
    "test:watch": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.1",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
